{
  "annotations": {
    "list": [
      {
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Per-model cost, throughput, and prompt-vs-output ratio for the ai-o11y-demo-apps stack. Built 2026-05-23 via MCP.",
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "\ud83d\udcb0 Headline cost numbers",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Sum of LLM cost across all models, all agents, all users for the last 24h.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#ff6b00"
          },
          "decimals": 2,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(increase(gen_ai_client_cost_usd_total{gen_ai_agent_name=~\"${agent:regex}\",gen_ai_system=~\"${provider:regex}\",gen_ai_request_model=~\"${model:regex}\"}[24h]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Total cost (last 24h)",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "24h cost extrapolated to 30 days (24h \u00d7 30). Linear projection \u2014 assumes current burn rate continues.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#ff3b6b"
          },
          "decimals": 2,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 8,
        "y": 1
      },
      "id": 3,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(increase(gen_ai_client_cost_usd_total{gen_ai_agent_name=~\"${agent:regex}\",gen_ai_system=~\"${provider:regex}\",gen_ai_request_model=~\"${model:regex}\"}[24h])) * 30",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Projected 30d cost",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Distinct models that produced cost-bearing calls in the last 24h.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#00f0ff"
          },
          "decimals": 0,
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 8,
        "x": 16,
        "y": 1
      },
      "id": 4,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "percentChangeColorMode": "standard",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "showPercentChange": false,
        "textMode": "value",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "count(count by (gen_ai_request_model) (increase(gen_ai_client_cost_usd_total{gen_ai_agent_name=~\"${agent:regex}\",gen_ai_system=~\"${provider:regex}\",gen_ai_request_model=~\"${model:regex}\"}[24h]) > 0))",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Active models (24h)",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 7
      },
      "id": 5,
      "title": "\ud83d\udcc8 Per-model cost & throughput",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Cost rate per model, displayed in $/hour. Anthropic models are ~100x more expensive than Ollama (which is local GPU = near-zero marginal cost).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "barWidthFactor": 0.9,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "lineWidth": 0,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "decimals": 4,
          "min": 0,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 8
      },
      "id": 6,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean",
            "max"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_cost_usd_total{gen_ai_agent_name=~\"${agent:regex}\",gen_ai_system=~\"${provider:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h])) * 3600",
          "interval": "1h",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ],
      "title": "$/hour by model",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Input (prompt) token throughput per model. Most calls are input-heavy (system prompt + tool defs + conversation history).",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "barWidthFactor": 0.9,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "lineWidth": 0,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "decimals": 1,
          "min": 0,
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 17
      },
      "id": 7,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\",gen_ai_agent_name=~\"${agent:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h]))",
          "interval": "1h",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ],
      "title": "Input tokens/sec by model",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Output (completion) token throughput per model. The product of completion length \u00d7 call rate.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "barWidthFactor": 0.9,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "lineWidth": 0,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "decimals": 1,
          "min": 0,
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 17
      },
      "id": 8,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\",gen_ai_agent_name=~\"${agent:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h]))",
          "interval": "1h",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ],
      "title": "Output tokens/sec by model",
      "type": "timeseries"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 26
      },
      "id": 9,
      "title": "\ud83d\udccb Per-model leaderboard (last 1h)",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Compares every model on calls, input tokens, output tokens, and cumulative spend in the trailing hour. Joined via joinByField on gen_ai_request_model.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Model"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 280
              },
              {
                "id": "custom.align",
                "value": "left"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Calls"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-blues"
                }
              },
              {
                "id": "fieldMinMax",
                "value": true
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Input Tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-purples"
                }
              },
              {
                "id": "fieldMinMax",
                "value": true
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Output Tokens"
            },
            "properties": [
              {
                "id": "unit",
                "value": "short"
              },
              {
                "id": "decimals",
                "value": 0
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-BlPu"
                }
              },
              {
                "id": "fieldMinMax",
                "value": true
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "$cost (1h)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-YlRd"
                }
              },
              {
                "id": "fieldMinMax",
                "value": true
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 27
      },
      "id": 10,
      "options": {
        "cellHeight": "md",
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "$cost (1h)"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_operation_duration_seconds_count{gen_ai_agent_name=~\"${agent:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "calls"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\",gen_ai_agent_name=~\"${agent:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "input"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\",gen_ai_agent_name=~\"${agent:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "output"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_cost_usd_total{gen_ai_agent_name=~\"${agent:regex}\",gen_ai_system=~\"${provider:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "cost"
        }
      ],
      "title": "Per-model leaderboard \u2014 calls, tokens, cost (1h)",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "gen_ai_request_model",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true
            },
            "indexByName": {
              "Value #calls": 1,
              "Value #cost": 4,
              "Value #input": 2,
              "Value #output": 3,
              "gen_ai_request_model": 0
            },
            "renameByName": {
              "Value #calls": "Calls",
              "Value #cost": "$cost (1h)",
              "Value #input": "Input Tokens",
              "Value #output": "Output Tokens",
              "gen_ai_request_model": "Model"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": true,
                "field": "$cost (1h)"
              }
            ]
          }
        }
      ],
      "type": "table"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 36
      },
      "id": 11,
      "title": "\u2696\ufe0f Prompt-vs-output ratio",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Input \u00f7 output token ratio per model. Higher = more prompt-heavy (lots of context, short answers). Typical Anthropic 5-20x. A value way out of band can flag stuffed system prompts.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "fixed",
            "fixedColor": "#b537ff"
          },
          "decimals": 2,
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 37
      },
      "id": 12,
      "options": {
        "colorMode": "background",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value_and_name",
        "wideLayout": true
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (increase(gen_ai_client_token_usage_sum{gen_ai_token_type=\"input\",gen_ai_agent_name=~\"${agent:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h])) / sum by (gen_ai_request_model) (increase(gen_ai_client_token_usage_sum{gen_ai_token_type=\"output\",gen_ai_agent_name=~\"${agent:regex}\",gen_ai_request_model=~\"${model:regex}\"}[1h]))",
          "instant": true,
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ],
      "title": "Input:output token ratio per model (1h)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "ai-o11y-demo-apps",
    "ai",
    "cost",
    "models"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "label": "Agent",
        "multi": true,
        "name": "agent",
        "query": {
          "query": "label_values(gen_ai_client_cost_usd_total{}, gen_ai_agent_name)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "label": "Provider",
        "multi": true,
        "name": "provider",
        "query": {
          "query": "label_values(gen_ai_client_cost_usd_total{}, gen_ai_system)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "label": "Model",
        "multi": true,
        "name": "model",
        "query": {
          "query": "label_values(gen_ai_client_cost_usd_total{}, gen_ai_request_model)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "label": "User",
        "multi": true,
        "name": "user_id",
        "query": {
          "query": "label_values(gen_ai_client_cost_usd_total{}, user_id)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "AI o11y \u2014 Cost & Efficiency per Model",
  "uid": null,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Your Grafana Cloud Prometheus datasource.",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    }
  ]
}