{
  "annotations": {
    "list": [
      {
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "description": "Revenue + AI ROI panels for the NeonCart app. Built 2026-05-23 via MCP.",
  "panels": [
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "\ud83d\udecd Add-to-Cart \u2014 by source & model",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "ATC events sliced by source. `manual` = direct shopper click. `ai_chatbot` = nc-chatbot suggested it. `ai_gift_finder` = gift-finder agent suggested it.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "barWidthFactor": 0.9,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "lineWidth": 0,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "decimals": 3,
          "min": 0,
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 0,
        "y": 1
      },
      "id": 2,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (source) (rate(neoncart_add_to_cart_total{service_namespace=\"ai-o11y-demo-apps\"}[1h])) * 3600",
          "interval": "1h",
          "legendFormat": "{{source}}",
          "refId": "A"
        }
      ],
      "title": "Add-to-Cart per source",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "ATC events sliced by gen_ai_request_model. Populates as the model label rolls out across new loadgen traffic (parallel commit landing 2026-05-23). Empty before that.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "barAlignment": 0,
            "barWidthFactor": 0.9,
            "drawStyle": "bars",
            "fillOpacity": 80,
            "gradientMode": "opacity",
            "lineWidth": 0,
            "spanNulls": false,
            "stacking": {
              "group": "A",
              "mode": "normal"
            }
          },
          "decimals": 3,
          "min": 0,
          "noValue": "(pending model-label rollout)",
          "unit": "short"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 12,
        "x": 12,
        "y": 1
      },
      "id": 3,
      "options": {
        "legend": {
          "calcs": [
            "lastNotNull",
            "mean"
          ],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_request_model) (rate(neoncart_add_to_cart_total{service_namespace=\"ai-o11y-demo-apps\",gen_ai_request_model!=\"unknown\",gen_ai_request_model!=\"\"}[1h])) * 3600",
          "interval": "1h",
          "legendFormat": "{{gen_ai_request_model}}",
          "refId": "A"
        }
      ],
      "title": "Add-to-Cart per model",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Ratio: AI-attributed ATC rate vs manual ATC rate. >1 = AI is suggesting more cart-adds than humans are clicking on their own. 1h window.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 0.5
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 5,
        "w": 8,
        "x": 0,
        "y": 10
      },
      "id": 4,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(neoncart_add_to_cart_total{service_namespace=\"ai-o11y-demo-apps\",source=~\"ai_.*\"}[1h])) / sum(rate(neoncart_add_to_cart_total{service_namespace=\"ai-o11y-demo-apps\",source=\"manual\"}[1h]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "AI conversion lift (AI ATC / manual ATC, 1h)",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 15
      },
      "id": 5,
      "title": "\ud83d\udcb5 Revenue",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Realized revenue from completed checkouts, projected to $/hour.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "custom": {
            "drawStyle": "line",
            "fillOpacity": 30,
            "gradientMode": "opacity",
            "lineInterpolation": "smooth",
            "lineWidth": 2,
            "spanNulls": false
          },
          "decimals": 2,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 16,
        "x": 0,
        "y": 16
      },
      "id": 6,
      "options": {
        "legend": {
          "showLegend": false
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(neoncart_revenue_usd_total{service_namespace=\"ai-o11y-demo-apps\"}[5m])) * 3600",
          "legendFormat": "revenue",
          "refId": "A"
        }
      ],
      "title": "Revenue rate ($/hour)",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Current 1h revenue rate projected forward by 7 days (rate \u00d7 86400 \u00d7 7). Linear extrapolation \u2014 assumes constant traffic.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "decimals": 2,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 9,
        "w": 8,
        "x": 16,
        "y": 16
      },
      "id": 7,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(neoncart_revenue_usd_total{service_namespace=\"ai-o11y-demo-apps\"}[1h])) * 86400 * 7",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "Projected weekly revenue",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Cumulative revenue attributed to AI agents (gift-finder + chatbot) in the trailing 24h.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-purples"
          },
          "decimals": 2,
          "unit": "currencyUSD"
        }
      },
      "gridPos": {
        "h": 6,
        "w": 24,
        "x": 0,
        "y": 25
      },
      "id": 8,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(increase(neoncart_ai_attributed_revenue_usd_total{service_namespace=\"ai-o11y-demo-apps\"}[24h]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "AI-attributed revenue (last 24h)",
      "type": "stat"
    },
    {
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 31
      },
      "id": 9,
      "title": "\ud83c\udfaf AI agent ROI",
      "type": "row"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Per-agent ROI: attributed_revenue / token_cost across the last hour. Anything > 1 means the agent earns more than its token cost. Joined on gen_ai_agent_name.",
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "left",
            "cellOptions": {
              "type": "auto"
            }
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Agent"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 240
              },
              {
                "id": "custom.align",
                "value": "left"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "AI Revenue (1h)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-GrYlRd"
                }
              },
              {
                "id": "fieldMinMax",
                "value": true
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Token Cost (1h)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "currencyUSD"
              },
              {
                "id": "decimals",
                "value": 4
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-YlRd"
                }
              },
              {
                "id": "fieldMinMax",
                "value": true
              },
              {
                "id": "custom.align",
                "value": "right"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "ROI (revenue/cost)"
            },
            "properties": [
              {
                "id": "unit",
                "value": "none"
              },
              {
                "id": "decimals",
                "value": 2
              },
              {
                "id": "custom.cellOptions",
                "value": {
                  "mode": "gradient",
                  "type": "gauge",
                  "valueDisplayMode": "text"
                }
              },
              {
                "id": "color",
                "value": {
                  "mode": "continuous-purples"
                }
              },
              {
                "id": "fieldMinMax",
                "value": true
              },
              {
                "id": "custom.align",
                "value": "right"
              },
              {
                "id": "min",
                "value": 0
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 9,
        "w": 24,
        "x": 0,
        "y": 32
      },
      "id": 10,
      "options": {
        "cellHeight": "md",
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "ROI (revenue/cost)"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_agent_name) (increase(neoncart_ai_attributed_revenue_usd_total{service_namespace=\"ai-o11y-demo-apps\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "rev"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_agent_name) (increase(gen_ai_client_cost_usd_total{service_namespace=\"ai-o11y-demo-apps\",gen_ai_agent_name=~\"nc-.*\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "cost"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum by (gen_ai_agent_name) (increase(neoncart_ai_attributed_revenue_usd_total{service_namespace=\"ai-o11y-demo-apps\"}[1h])) / on(gen_ai_agent_name) sum by (gen_ai_agent_name) (increase(gen_ai_client_cost_usd_total{service_namespace=\"ai-o11y-demo-apps\",gen_ai_agent_name=~\"nc-.*\"}[1h]))",
          "format": "table",
          "instant": true,
          "refId": "roi"
        }
      ],
      "title": "Per-agent ROI (1h)",
      "transformations": [
        {
          "id": "joinByField",
          "options": {
            "byField": "gen_ai_agent_name",
            "mode": "outer"
          }
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time 1": true,
              "Time 2": true,
              "Time 3": true
            },
            "indexByName": {
              "Value #cost": 2,
              "Value #rev": 1,
              "Value #roi": 3,
              "gen_ai_agent_name": 0
            },
            "renameByName": {
              "Value #cost": "Token Cost (1h)",
              "Value #rev": "AI Revenue (1h)",
              "Value #roi": "ROI (revenue/cost)",
              "gen_ai_agent_name": "Agent"
            }
          }
        },
        {
          "id": "sortBy",
          "options": {
            "fields": {},
            "sort": [
              {
                "desc": true,
                "field": "ROI (revenue/cost)"
              }
            ]
          }
        }
      ],
      "type": "table"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "description": "Combined AI agent ROI \u2014 attributed revenue / token cost over the last hour, across ALL nc-* agents. > 1.0 = AI pays for itself. < 1.0 = bleeding.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "continuous-GrYlRd"
          },
          "decimals": 1,
          "unit": "none"
        }
      },
      "gridPos": {
        "h": 7,
        "w": 24,
        "x": 0,
        "y": 41
      },
      "id": 11,
      "options": {
        "colorMode": "background_solid",
        "graphMode": "area",
        "justifyMode": "center",
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ]
        },
        "textMode": "value"
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "expr": "sum(rate(neoncart_ai_attributed_revenue_usd_total{service_namespace=\"ai-o11y-demo-apps\"}[1h])) / sum(rate(gen_ai_client_cost_usd_total{service_namespace=\"ai-o11y-demo-apps\",gen_ai_agent_name=~\"nc-.*\"}[1h]))",
          "instant": true,
          "refId": "A"
        }
      ],
      "title": "AI agent ROI (combined, 1h)",
      "type": "stat"
    }
  ],
  "refresh": "30s",
  "schemaVersion": 39,
  "tags": [
    "ai-o11y-demo-apps",
    "neoncart",
    "business",
    "roi"
  ],
  "templating": {
    "list": [
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "label": "Agent",
        "multi": true,
        "name": "agent",
        "query": {
          "query": "label_values(gen_ai_client_cost_usd_total{service_namespace=\"ai-o11y-demo-apps\",gen_ai_agent_name=~\"nc-.*\"}, gen_ai_agent_name)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "label": "Provider",
        "multi": true,
        "name": "provider",
        "query": {
          "query": "label_values(gen_ai_client_cost_usd_total{service_namespace=\"ai-o11y-demo-apps\",gen_ai_agent_name=~\"nc-.*\"}, gen_ai_system)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      },
      {
        "allValue": ".+",
        "current": {
          "text": "All",
          "value": [
            "$__all"
          ]
        },
        "datasource": {
          "type": "prometheus",
          "uid": "${DS_PROMETHEUS}"
        },
        "includeAll": true,
        "label": "Model",
        "multi": true,
        "name": "model",
        "query": {
          "query": "label_values(gen_ai_client_cost_usd_total{service_namespace=\"ai-o11y-demo-apps\",gen_ai_agent_name=~\"nc-.*\"}, gen_ai_request_model)"
        },
        "refresh": 2,
        "sort": 1,
        "type": "query"
      }
    ]
  },
  "time": {
    "from": "now-6h",
    "to": "now"
  },
  "timezone": "browser",
  "title": "AI o11y \u2014 NeonCart Business Impact",
  "uid": null,
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Your Grafana Cloud Prometheus datasource (typically named grafanacloud-prom).",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "11.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "table",
      "name": "Table",
      "version": ""
    },
    {
      "type": "panel",
      "id": "barchart",
      "name": "Bar chart",
      "version": ""
    }
  ]
}