# users.yaml — synthetic user pool consumed by the loadgen orchestrator.
#
# This example shows the schema with ~5 users per cohort. The real file
# is generated by `tools/regenerate-users.py --seed 42 > config/users.yaml`
# (default: 200 NC users + 30 SB users using the Python `faker` library).
#
# Hand-edits are SUPPORTED — only re-running the regen script overwrites
# the file. Don't auto-regenerate on startup. To customize a single user
# (e.g., make a specific email act as the data-theft extension's persona),
# just edit the entry in place.
#
# Cohort assignment is STABLE: a "gift_finder" user always uses the
# gift-finder, never the chatbot, across all their sessions.
#
# Fields:
#   name     — display name (informational; not sent to the apps)
#   email    — synthetic email; this is the `user_id` label on OTel metrics
#   cohort   — one of: non_ai | gift_finder | chatbot | both     (NC users)
#   role     — Acme employee role: ic|manager|hr|finance|legal|exec|contractor (SB users)
#
# Optional fields any cohort can carry:
#   tags     — list of free-form tags for dashboards (unused in the base demo)

nc_users:
